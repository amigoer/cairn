{{- $sections := slice "posts" -}}
{{- $pages := where .Site.RegularPages "Section" "in" $sections -}}
{{- if not .IsHome -}}
  {{- $pages = .Pages -}}
{{- end -}}
{{- $title := cond .IsHome .Site.Title (printf "%s · %s" .Title .Site.Title) -}}
{{- $author := .Site.Params.author | default .Site.Title -}}
{{- $email := .Site.Params.email | default "" -}}
{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ $title }}</title>
  <subtitle>{{ with .Description }}{{ . }}{{ else }}{{ .Site.Params.description | default .Site.Title }}{{ end }}</subtitle>
  <link href="{{ .Permalink }}" rel="alternate" type="text/html" />
  <link href="{{ .Permalink }}atom.xml" rel="self" type="application/atom+xml" />
  <id>{{ .Permalink }}</id>
  <updated>{{ now.Format "2006-01-02T15:04:05Z07:00" | safeHTML }}</updated>
  <rights>© {{ now.Year }} {{ $author }}</rights>
  <generator uri="https://gohugo.io/">Hugo + amigoer</generator>
  <author>
    <name>{{ $author }}</name>
    {{ with $email }}<email>{{ . }}</email>{{ end }}
  </author>
  {{ range first 30 $pages.ByDate.Reverse }}
  <entry>
    <title>{{ .Title }}</title>
    <link href="{{ .Permalink }}" rel="alternate" type="text/html" />
    <id>{{ .Permalink }}</id>
    <published>{{ .Date.Format "2006-01-02T15:04:05Z07:00" | safeHTML }}</published>
    <updated>{{ .Lastmod.Format "2006-01-02T15:04:05Z07:00" | safeHTML }}</updated>
    <author>
      <name>{{ $author }}</name>
      {{ with $email }}<email>{{ . }}</email>{{ end }}
    </author>
    <summary type="html">{{ truncate 200 "…" (.Summary | plainify) | transform.XMLEscape | safeHTML }}</summary>
    <content type="html">{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</content>
    {{ range .Params.categories }}<category term="{{ . }}" />{{ end }}
    {{ range .Params.tags }}<category term="{{ . }}" />{{ end }}
  </entry>
  {{ end }}
</feed>
